---
import Layout from "@/layouts/Layout.astro";
import ContactSection from "@/components/ui/ContactSecction.astro";
import WorkTimeline from "@/components/react/TimeLine";
import ImageCard from "@/components/cards/ImageCard.astro";
import SocialApps from "@/components/ui/SocialApps.astro";
import Button from "@/components/ui/buttons/Button.astro";
import CV from "@/assets/docs/CV-Alessandro_Diaz.pdf";
import { defaultLang, translations, type Language } from "@/lib/i18n";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
---

<Layout title={t.seo.pages.hireTitle} description={t.seo.pages.hireDescription}>
    <div class="pt-40 relative max-w-7xl container mx-auto px-4 sm:px-6 lg:px-8" data-motion-section="hire">

        <!-- Page header -->
        <div class="text-center mb-20" data-motion-header>
            <p class="section-kicker mb-5">
                {lang === "es" ? "Disponible para colaborar" : "Available for work"}
            </p>
            <h1 class="text-3xl font-semibold text-white sm:text-5xl lg:text-[clamp(2.5rem,5vw,3.5rem)]">
                {t.seo.pages.hireTitle}
            </h1>
            <p class="mt-4 text-base text-neutral-500 max-w-xl mx-auto leading-[1.8]" data-motion-copy>
                {t.seo.pages.hireDescription}
            </p>
        </div>

        <!-- Avatar + contact -->
        <div class="grid grid-cols-1 md:grid-cols-2 items-start gap-12 mb-20">
            <div class="flex flex-col items-center gap-8" data-motion-panel>
                <ImageCard />
                <SocialApps />
                <Button
                    href={CV}
                    text={t.hireMe.downloadMyCv}
                    downloadAttr={true}
                    downloadAttributeValue="CV-Alessandro_Diaz.pdf"
                    target="_blank"
                    ariaLabel={t.hireMe.downloadMyCv}
                />
            </div>

            <ContactSection />
        </div>

        <!-- Timeline section -->
        <div class="relative py-20 mx-0">
            <!-- Gold dot grid — replaces green -->
            <div
                class="absolute inset-0 -z-10"
                style="background: radial-gradient(rgba(232, 168, 48, 0.35) 0.5px, transparent 0.5px); background-size: 28px 28px; mask-image: radial-gradient(ellipse 38% 48% at 50% 50%, #000 70%, transparent 100%);"
            ></div>

            <WorkTimeline client:only="react" timeline={t.timeline} />
        </div>
    </div>
</Layout>
