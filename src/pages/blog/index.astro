---
import Layout from "@/layouts/Layout.astro";
import { HeroVideoDialog } from "@/components/react/VideoDialog";
import { BlogComputerAscii } from "@/components/react/BlogComputerAscii";
import BlogGrid from "@/components/BlogGrid.astro";
import Subscribe from "@/components/ui/forms/Subscribe.astro";
import { defaultLang, translations, type Language } from "@/lib/i18n";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
---

<Layout
    title={t.seo.pages.blogTitle}
    description={t.seo.pages.blogDescription}
>
    <div class="relative z-10 mx-auto max-w-7xl px-4 pb-8 pt-32 sm:px-6 md:pb-10 lg:px-8 lg:pb-12 lg:pt-32">
        <section class="grid items-center gap-8 lg:grid-cols-[minmax(0,1.18fr)_minmax(0,0.82fr)] lg:gap-6">
            <div class="min-w-0">
                <div class="flex justify-start gap-2">
                    <h2
                        class="w-fit rounded-full border border-primary-green/40 bg-primary-green/20 px-4 py-2 text-center text-sm font-medium leading-6 tracking-wider text-primary-green"
                    >
                        {t.blogIndex.badge}
                    </h2>
                </div>
                <h1
                    class="my-8 flex max-w-5xl flex-col text-left text-5xl font-bold leading-[0.95] sm:text-6xl md:text-7xl xl:text-8xl"
                >
                    {t.blogIndex.titleLeading}<span
                        class="text-primary-green [text-shadow:0_0_60px_#00D47C]"
                        >{t.blogIndex.titleHighlight}</span
                    >
                </h1>

                <div class="flex flex-col items-start justify-center gap-2">
                    <article>
                        <p
                            class="max-w-3xl text-left text-sm leading-7 text-neutral-400 sm:text-base"
                        >
                            {t.blogIndex.description}
                        </p>
                    </article>
                    <div class="mt-8 flex gap-2">
                        <div class="h-1.5 w-12 rounded-full bg-primary glow-effect">
                        </div>
                        <div class="h-1.5 w-12 rounded-full bg-secondary">
                        </div>
                        <div class="h-1.5 w-12 rounded-full bg-accent"></div>
                    </div>
                </div>

                <div class="surface-panel mt-10 w-full max-w-2xl overflow-hidden p-2">
                    <HeroVideoDialog
                        client:idle
                        className="z-50 block w-full dark:hidden"
                        animationStyle="from-right"
                        videoSrc="https://www.youtube.com/embed/JOfbnXdXRFM"
                        thumbnailSrc="https://res.cloudinary.com/drwd1wtvt/image/upload/v1768491823/cover_r5suhi.jpg"
                        thumbnailAlt={t.blogIndex.thumbnailAlt}
                        playLabel={t.blogIndex.playLabel}
                        playerTitle={t.blogIndex.playerTitle}
                    />
                    <HeroVideoDialog
                        client:idle
                        className="z-50 hidden w-full dark:block"
                        animationStyle="from-left"
                        videoSrc="https://www.youtube.com/embed/JOfbnXdXRFM"
                        thumbnailSrc="https://res.cloudinary.com/drwd1wtvt/image/upload/v1768491823/cover_r5suhi.jpg"
                        thumbnailAlt={t.blogIndex.thumbnailAlt}
                        playLabel={t.blogIndex.playLabel}
                        playerTitle={t.blogIndex.playerTitle}
                    />
                </div>
            </div>

            <BlogComputerAscii client:visible className="lg:min-h-[30rem]" />
        </section>
    </div>

    <BlogGrid />
    <Subscribe />
</Layout>
