---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/ui/Hero.astro";
import FeaturedProjects from "@/components/ui/FeaturedProjects.astro";
import AboutMe from "@/components/AboutMe.astro";
import BlogSection from "@/components/ui/BlogSection.astro";
import ContactSection from "@/components/ui/ContactSecction.astro";
import WorkTimeline from "@/components/react/TimeLine";
import { defaultLang, translations, type Language } from "@/lib/i18n";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
---

<Layout
    title={t.seo.pages.homeTitle}
    description={t.seo.pages.homeDescription}
>
    <Hero />
    <FeaturedProjects limit={2} />
    <section class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
        <div class="absolute inset-0 -z-10 bg-[radial-gradient(rgba(0,212,124,0.18)_1px,transparent_1px)] bg-size-[28px_28px] opacity-40 mask-[radial-gradient(ellipse_55%_45%_at_50%_42%,#000_40%,transparent_78%)]"></div>

        <WorkTimeline client:only="react" timeline={t.timeline} />
    </section>
    <AboutMe />
    <BlogSection />
    <ContactSection />
</Layout>
