---
import avatar from "@/assets/avatar2.png";
import { Image } from "astro:assets";
import Button from "../ui/buttons/Button.astro";
import { defaultLang, translations, type Language } from "@/lib/i18n";
import Globe from "@/components/ui/icons/Globe.astro";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
const nextLang: Language = lang === "en" ? "es" : "en";
const toggleLabel = nextLang.toUpperCase();
const toggleAriaLabel =
    nextLang === "es"
        ? t.languageToggle.switchToEs
        : t.languageToggle.switchToEn;
---

<script>
    const setupEventListeners = () => {
        const hamburger = document.getElementById("hamburger");
        const mobileMenu = document.getElementById("mobileMenu");
        const mobileNavLinks = document.querySelectorAll(
            "#mobileMenu nav ul li a",
        );

        // ONLY attach listeners if they haven't been attached yet
        if (!hamburger || !mobileMenu || (hamburger as any)._listenersAttached)
            return;

        // Hamburger menu toggle
        hamburger.addEventListener("click", (e) => {
            e.stopPropagation();
            hamburger.classList.toggle("open");
            mobileMenu.classList.toggle("translate-x-full");
        });

        // Close mobile menu after link selection
        mobileNavLinks.forEach((link) => {
            link.addEventListener("click", () => {
                mobileMenu.classList.add("translate-x-full");
                hamburger.classList.remove("open");
            });
        });

        // Close menu when clicking outside
        document.addEventListener("click", (e) => {
            const target = e.target as HTMLElement;
            if (
                mobileMenu &&
                hamburger &&
                !mobileMenu.contains(target) &&
                !hamburger.contains(target) &&
                !mobileMenu.classList.contains("translate-x-full")
            ) {
                mobileMenu.classList.add("translate-x-full");
                hamburger.classList.remove("open");
            }
        });

        (hamburger as any)._listenersAttached = true;
    };

    const updateActiveState = () => {
        const currentPath = window.location.pathname;
        const activeClasses =
            "bg-primary-green text-black border-primary-green shadow-[0_0_24px_rgba(0,212,124,0.22)]".split(
                " ",
            );
        const inactiveClasses =
            "border border-white/10 bg-black/45 text-neutral-300 hover:border-primary-green/60 hover:text-white".split(
                " ",
            );

        const allLinks = document.querySelectorAll(
            "#headerContainer nav ul li a, #mobileMenu nav ul li a",
        );

        allLinks.forEach((link) => {
            const href = link.getAttribute("href");
            link.classList.remove(...activeClasses);
            link.classList.add(...inactiveClasses);

            if (href === currentPath || (currentPath === "/" && href === "/")) {
                link.classList.remove(...inactiveClasses);
                link.classList.add(...activeClasses);
            }
        });

        // Ensure menu is closed on navigation
        const hamburger = document.getElementById("hamburger");
        const mobileMenu = document.getElementById("mobileMenu");
        if (hamburger && mobileMenu) {
            hamburger.classList.remove("open");
            mobileMenu.classList.add("translate-x-full");
        }
    };

    const runHeaderSetup = () => {
        setupEventListeners();
        updateActiveState();
    };

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", runHeaderSetup, {
            once: true,
        });
    } else {
        runHeaderSetup();
    }

    // Run on view transition updates
    document.addEventListener("astro:page-load", runHeaderSetup);
    document.addEventListener("astro:after-swap", () => {
        runHeaderSetup();
    });
</script>

<header
    transition:persist="true"
    class="fixed top-0 left-0 right-0 z-50"
    data-aos="fade-down"
    data-aos-duration="1000"
    data-aos-delay="120"
>
    <div
        class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8"
        id="headerContainer"
    >
        <a href="/" class="group flex items-center rounded-full border border-white/10 bg-black/50 p-1.5 backdrop-blur-xl transition-colors hover:border-primary-green/60 sm:gap-3 sm:pr-4">
            <div
                class="flex h-11 w-11 items-center justify-center overflow-hidden rounded-full border border-primary-green/60 bg-primary-green/10"
            >
                <Image
                    class="h-12 w-auto"
                    src={avatar}
                    alt={t.nav.profileAlt}
                />
            </div>
            <span class="hidden font-mono text-xs uppercase tracking-[0.22em] text-neutral-300 transition-colors group-hover:text-primary-green sm:inline">
                Alessandro Diaz
            </span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden md:block">
            <ul class="flex items-center gap-2.5 text-sm">
                <li>
                    <a
                        href="/"
                        class="rounded-full px-6 py-2.5 transition-all duration-300"
                        >{t.nav.home}</a
                    >
                </li>
                <li>
                    <a
                        href="/my-projects"
                        class="rounded-full px-6 py-2.5 transition-all duration-300"
                        >{t.nav.projects}</a
                    >
                </li>
                <li>
                    <a
                        href="/blog"
                        class="rounded-full px-6 py-2.5 transition-all duration-300"
                        >{t.nav.blog}</a
                    >
                </li>
            </ul>
        </nav>

        <div class="flex items-center gap-2">
            <button
                id="lang-toggle"
                type="button"
                class="inline-flex items-center justify-center rounded-full border border-white/10 bg-black/50 p-2.5 text-white backdrop-blur-xl transition-all duration-300 hover:cursor-pointer hover:border-primary-green/60 hover:text-primary-green"
                aria-label={toggleAriaLabel}
                data-next-lang={nextLang}
            >
                <Globe class="h-5 w-5" aria-hidden="true" />
                <span class="sr-only">{toggleLabel}</span>
            </button>
            <div class="hidden sm:block">
                <Button
                    text={t.nav.hireMe}
                    variant="primary"
                    href="/hire-me"
                    ariaLabel={t.nav.hireMe}
                />
            </div>

            <!-- Mobile Hamburger Button -->
            <button
                id="hamburger"
                class="relative flex h-10 w-10 flex-col items-center justify-center gap-1.5 rounded-lg border border-white/10 bg-black/50 backdrop-blur-xl transition-all duration-300 hover:bg-white/10 sm:hidden"
                aria-label={t.nav.toggleMenu}
            >
                <span
                    class="block w-6 h-0.5 bg-white rounded-full transition-all duration-300"
                ></span>
                <span
                    class="block w-6 h-0.5 bg-white rounded-full transition-all duration-300"
                ></span>
                <span
                    class="block w-6 h-0.5 bg-white rounded-full transition-all duration-300"
                ></span>
            </button>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div
        id="mobileMenu"
        class="fixed top-0 right-0 h-screen h-[100dvh] min-h-[100svh] w-[clamp(16rem,88vw,24rem)] transform border-l border-white/10 bg-black/85 shadow-2xl backdrop-blur-2xl transition-transform duration-300 ease-in-out translate-x-full md:hidden"
    >
        <div class="flex flex-col h-full p-6 pt-20">
            <!-- Mobile Navigation -->
            <nav class="flex-1">
                <ul class="flex flex-col gap-3 text-white">
                    <li>
                        <a
                            href="/"
                            class="block rounded-xl px-6 py-3 text-center font-medium transition-all duration-300"
                            >{t.nav.home}</a
                        >
                    </li>
                    <li>
                        <a
                            href="/my-projects"
                            class="block rounded-xl px-6 py-3 text-center font-medium transition-all duration-300"
                            >{t.nav.projects}</a
                        >
                    </li>
                    <li>
                        <a
                            href="/blog"
                            class="block rounded-xl px-6 py-3 text-center font-medium transition-all duration-300"
                            >{t.nav.blog}</a
                        >
                    </li>
                    <li>
                        <Button
                            text={t.nav.hireMe}
                            variant="primary"
                            href="/hire-me"
                            ariaLabel={t.nav.hireMe}
                            className="w-full px-6 py-3 rounded-xl text-center shadow-none !text-base !font-medium"
                        />
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</header>

<style>
    /* Hamburger animation */
    #hamburger.open span:nth-child(1) {
        transform: translateY(8px) rotate(45deg);
    }

    #hamburger.open span:nth-child(2) {
        opacity: 0;
    }

    #hamburger.open span:nth-child(3) {
        transform: translateY(-8px) rotate(-45deg);
    }
</style>
