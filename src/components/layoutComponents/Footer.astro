---
import Button from "@/components/ui/buttons/Button.astro";
import Flag from "@/components/ui/icons/Flag.astro";
import SocialApps from "@/components/ui/SocialApps.astro";
import footerImage from "@/assets/FooterAvatar.png";
import { defaultLang, translations, type Language } from "@/lib/i18n";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
const year = new Date().getFullYear();
const footerLinkClass =
    "inline-flex rounded-md border border-transparent px-2 py-1 -mx-2 text-neutral-300 transition-all duration-300 hover:border-primary-green/20 hover:bg-primary-green/8 hover:text-primary-green focus-visible:border-primary-green/35 focus-visible:bg-primary-green/10 focus-visible:text-primary-green focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-green/15";
---

<footer class="relative z-10 mx-auto max-w-7xl px-4 pb-10 pt-16 sm:px-6 lg:px-8">
    <div class="hairline mb-10"></div>

    <article class="grid gap-8 lg:grid-cols-[1fr_0.7fr_0.9fr]">
        <div class="surface-panel p-6">
            <p class="section-kicker">{t.footer.getInTouch}</p>
            <h3 class="mt-4 text-3xl font-semibold text-white">
                Alessandro Diaz
            </h3>
            <p class="mt-4 max-w-xl text-sm leading-7 text-neutral-400">
                {t.footer.tagline}
            </p>
            <div class="mt-6 flex flex-wrap items-center gap-3">
                <Button
                    text={t.socialLinks.scheduleMeeting}
                    variant="secondary"
                    href="/hire-me"
                    ariaLabel={t.socialLinks.scheduleMeetingAria}
                />
                <SocialApps />
            </div>
        </div>

        <nav class="surface-panel p-6">
            <p class="section-kicker">{t.footer.interestLinks}</p>
            <ul class="mt-5 grid gap-3 text-sm text-neutral-400">
                <li>
                    <a class={footerLinkClass} href="/my-projects">
                        {t.footer.projects}
                    </a>
                </li>
                <li>
                    <a class={footerLinkClass} href="/blog">
                        {t.footer.blog}
                    </a>
                </li>
                <li>
                    <a
                        class={footerLinkClass}
                        href="https://nous.cr"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={t.footer.visitNousAria}
                    >
                        {t.footer.knowInitiative}
                    </a>
                </li>
                <li>
                    <a
                        class={footerLinkClass}
                        href="/hire-me"
                        aria-label={t.footer.contactAria}
                    >
                        {t.footer.contactMe}
                    </a>
                </li>
            </ul>
        </nav>

        <div class="surface-panel relative min-h-72 overflow-hidden p-6">
            <img
                class="absolute -bottom-2 -right-4 max-h-64 opacity-25"
                src={footerImage.src}
                alt=""
                loading="lazy"
                decoding="async"
                style={{
                    WebkitMaskImage:
                        "linear-gradient(to top, transparent 0%, #000 28%, #000 100%)",
                    maskImage:
                        "linear-gradient(to top, transparent 0%, #000 28%, #000 100%)",
                    WebkitMaskRepeat: "no-repeat",
                    maskRepeat: "no-repeat",
                    WebkitMaskSize: "100% 100%",
                    maskSize: "100% 100%",
                }}
            />
            <div class="relative z-20 max-w-[14rem]">
                <p class="section-kicker">{t.seo.siteName}</p>
                <div class="mt-4 inline-flex items-center gap-2 text-lg font-medium text-white">
                    {t.footer.madeIn}
                    <Flag />
                </div>
                <p class="mt-6 text-sm font-medium leading-7 text-white drop-shadow-[0_2px_14px_rgba(0,0,0,0.95)]">
                    {t.footer.builtWith}
                </p>
            </div>
        </div>
    </article>

    <p class="mt-8 text-xs text-neutral-600">
        {t.footer.copyright.replace("{year}", String(year))}
    </p>
</footer>
