---
import GoToAll from "@/components/ui/icons/goToAll.astro";
import nous from "@/assets/videos/nous.webm";
import erlingnails from "@/assets/videos/erlingnails.webm";
import cms from "@/assets/videos/cms.webm";
import apv from "@/assets/apv-api.webp";
import apv_front from "@/assets/videos/apv-mern.webm";
import blogApi from "@/assets/blog-api.webp";
import { defaultLang, translations, type Language } from "@/lib/i18n";

export interface FeaturedProject {
    title: string;
    description: string;
    image: string;
    tags: string[];
    link: string;
    haveRepo: boolean;
    repoLink?: string;
    isVideo?: boolean;
}

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];

const {
    limit,
    showAllLink = true,
    heading = t.featuredProjects.heading,
    description = t.featuredProjects.description,
    viewAllLabel = t.featuredProjects.viewAll,
    headingLevel = 2,
} = Astro.props;

const HeadingTag = headingLevel === 1 ? "h1" : "h2";

const projects: FeaturedProject[] = [
    {
        title: "NOUS",
        description: t.projects.nous.description,
        image: nous,
        tags: [
            "Astro",
            "Typescrypt",
            "PostgreSQL",
            "Tailwind CSS",
            "React.js",
            "Node.js",
        ],
        link: "https://nous.cr",
        haveRepo: false,
        isVideo: true,
    },
    {
        title: "Content Management System",
        description: t.projects.cms.description,
        image: cms,
        tags: [
            "Astro",
            "Typescrypt",
            "PostgreSQL",
            "Tailwind CSS",
            "React.js",
            "Node.js",
        ],
        link: "https://cms-only-test.vercel.app",
        haveRepo: true,
        repoLink: "https://github.com/Alessandro1809/cms-personal-blog",
        isVideo: true,
    },
    {
        title: "Veterinary Patient Management",
        description: t.projects.apvFrontend.description,
        image: apv_front,
        tags: ["React.js", "Javascript", "Axios", "Tailwind CSS"],
        link: "https://frontend-apv-mern.vercel.app/",
        haveRepo: true,
        repoLink: "https://github.com/Alessandro1809/Frontend_APV_MERN",
        isVideo: true,
    },
    {
        title: "Erling Nails",
        description: t.projects.erlingNails.description,
        image: erlingnails,
        tags: [
            "Astro",
            "Typescrypt",
            "PostgreSQL",
            "Tailwind CSS",
            "React.js",
            "Node.js",
        ],
        link: "https://www.erlingnails.com/",
        haveRepo: true,
        repoLink: "https://github.com/Alessandro1809/erling-nails-v1",
        isVideo: true,
    },
    {
        title: "Veterinary patient management API",
        description: t.projects.apvApi.description,
        image: apv.src,
        tags: ["Express.js", "Javascript", "MongoDB", "Email.js", "Node.js"],
        link: "https://apv-docs.netlify.app/",
        haveRepo: true,
        repoLink: "https://github.com/Alessandro1809/MERN_APV_Backend",
        isVideo: false,
    },
    {
        title: "Blog API",
        description: t.projects.blogApi.description,
        image: blogApi.src,
        tags: [
            "Fastify",
            "Typescript",
            "Drizzle",
            "Clerk",
            "Node.js",
            "SQLite",
            "Vitest",
            "Supertest",
        ],
        link: "https://blogapidocs.netlify.app/",
        haveRepo: true,
        repoLink: "https://github.com/Alessandro1809/blog-api",
        isVideo: false,
    },
];

const displayedProjects =
    typeof limit === "number" ? projects.slice(0, limit) : projects;
---

<section class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <header
        class="mb-10 grid gap-6 lg:grid-cols-[0.9fr_1fr] lg:items-end"
        data-aos="fade-up"
        data-aos-duration="800"
        data-aos-once="true"
    >
        <div>
            <p class="section-kicker">{t.nav.projects}</p>
            <HeadingTag class="mt-4 text-3xl font-semibold text-white sm:text-5xl">
                {heading}
            </HeadingTag>
        </div>

        <div class="flex flex-col gap-5 lg:items-end">
            <p class="max-w-2xl text-sm leading-7 text-neutral-400 lg:text-right">
                {description}
            </p>
            {
                showAllLink && (
                    <a
                        href="/my-projects"
                        class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.22em] text-primary-green transition-colors hover:text-white"
                    >
                        {viewAllLabel}
                        <GoToAll />
                    </a>
                )
            }
        </div>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
        {
            displayedProjects.map((project, index) => (
                <article
                    class="group surface-panel relative overflow-hidden"
                    data-aos="fade-up"
                    data-aos-duration="800"
                    data-aos-delay={index * 80}
                    data-aos-once="true"
                >
                    <a
                        href={project.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={project.title}
                        class="block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-green/70"
                    >
                        <div class="relative aspect-[16/10] overflow-hidden bg-black lg:aspect-[16/11]">
                            {project.isVideo ? (
                                <video
                                    class="project-video h-full w-full object-cover opacity-80 saturate-[0.85] transition duration-700 group-hover:scale-[1.03] group-hover:opacity-100"
                                    autoplay
                                    muted
                                    loop
                                    playsinline
                                    preload="metadata"
                                    src={project.image}
                                />
                            ) : (
                                <img
                                    src={project.image}
                                    alt={project.title}
                                    class="h-full w-full object-cover opacity-80 saturate-[0.85] transition duration-700 group-hover:scale-[1.03] group-hover:opacity-100"
                                    loading="lazy"
                                    decoding="async"
                                />
                            )}
                            <div class="absolute inset-0 bg-linear-to-t from-black via-black/25 to-transparent"></div>
                            <div class="absolute left-4 top-4 rounded-full border border-white/10 bg-black/60 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-[0.2em] text-neutral-300 backdrop-blur-xl">
                                0{index + 1}
                            </div>
                        </div>
                    </a>

                    <div class="p-5 sm:p-6">
                        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                            <h3 class="text-2xl font-semibold text-white">
                                {project.title}
                            </h3>
                            {project.haveRepo && (
                                <a
                                    href={project.repoLink}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-white transition hover:border-primary-green/70 hover:text-primary-green"
                                    aria-label={t.featuredProjects.repoAria}
                                >
                                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                    </svg>
                                </a>
                            )}
                        </div>

                        <p class="mt-4 line-clamp-5 text-sm leading-7 text-neutral-400">
                            {project.description}
                        </p>

                        <footer class="mt-5 flex flex-wrap gap-2">
                            {project.tags.map((tag) => (
                                <span class="rounded-full border border-primary-green/20 bg-primary-green/10 px-3 py-1 font-mono text-[0.65rem] uppercase tracking-[0.14em] text-primary-green/90">
                                    {tag}
                                </span>
                            ))}
                        </footer>
                    </div>
                </article>
            ))
        }
    </div>
</section>

<script>
    document.addEventListener("astro:page-load", () => {
        const videos = document.querySelectorAll<HTMLVideoElement>(".project-video");
        videos.forEach((video) => {
            video.playbackRate = 1.35;
        });
    });
</script>
