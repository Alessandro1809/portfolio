---
import Button from "@/components/ui/buttons/Button.astro";
import SocialLinks from "@/components/ui/SocialLinks.astro";
import { AsciiStudioPanel } from "@/components/react/AsciiStudioPanel";
import CV from "@/assets/docs/CV-Alessandro_Diaz.pdf";
import { defaultLang, translations, type Language } from "@/lib/i18n";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
---

<section
    id="hero-section"
    class="relative mx-auto grid min-h-screen max-w-7xl items-center gap-10 px-4 pb-20 pt-32 sm:px-6 lg:grid-cols-[minmax(0,1.18fr)_minmax(0,0.82fr)] lg:gap-6 lg:px-8 lg:pt-28"
>
    <div class="relative z-10 min-w-0">
        <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/[0.035] px-4 py-2 font-mono text-xs uppercase tracking-[0.24em] text-neutral-300 backdrop-blur-xl">
            <span class="h-2 w-2 rounded-full bg-primary-green shadow-[0_0_16px_rgba(0,212,124,0.8)]"></span>
            {t.profile.title}
        </div>

        <h1
            class="glitch-title max-w-5xl text-4xl font-semibold leading-[0.98] text-white sm:text-6xl lg:text-6xl xl:text-7xl"
            data-text={t.hero.title}
        >
            {t.hero.title}
        </h1>

        <p
            class="mt-8 max-w-2xl text-pretty text-base leading-8 text-neutral-300 sm:text-lg"
        >
            {t.hero.subtitle}
        </p>

        <div
            class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center"
        >
            <Button
                text={t.hero.downloadCv}
                variant="primary"
                downloadAttr={true}
                downloadAttributeValue="CV-Alessandro_Diaz.pdf"
                href={CV}
                target="_blank"
                ariaLabel={t.hero.downloadCvAria}
            />
            <Button
                text={t.nav.hireMe}
                variant="secondary"
                href="/hire-me"
                ariaLabel={t.nav.hireMe}
            />
        </div>

        <div>
            <SocialLinks />
        </div>
    </div>

    <div class="relative z-10 min-w-0">
        <AsciiStudioPanel
            client:load
            name={t.seo.siteName}
            title={t.profile.title}
            subtitle={t.hero.subtitle}
            className="lg:justify-items-start"
        />
    </div>
</section>
