---
export interface SocialLink {
    href: string;
    label: string;
}

const links: SocialLink[] = [
    {
        href: "https://github.com/Alessandro1809",
        label: "GitHub",
    },
    {
        href: "https://www.linkedin.com/in/alessandrodg/",
        label: "LinkedIn",
    },
    {
        href: "https://x.com/ddiaz_ale",
        label: "X",
    },
];
---

<div class="flex flex-wrap gap-2">
    {
        links.map((link) => (
            <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${link.label}, opens in new tab`}
                class="rounded-md border border-white/10 bg-white/[0.025] px-3 py-2 font-mono text-[0.68rem] tracking-[0.12em] text-neutral-400 transition-all duration-250 hover:border-primary-green/55 hover:text-primary-green"
            >
                {link.label}
            </a>
        ))
    }
</div>
