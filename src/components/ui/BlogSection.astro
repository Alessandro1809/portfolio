---
import Coffee from "@/components/ui/icons/Coffee.astro";
import GoToAll from "@/components/ui/icons/goToAll.astro";
const { turso } = Astro.locals;
import { ArrowUpRight } from "lucide-react";
import {
    defaultLang,
    localeByLang,
    translations,
    type Language,
} from "@/lib/i18n";
import { formatDate } from "@/lib/date";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
const locale = localeByLang[lang];

let recentPosts: any[] = [];
if (!turso) {
    console.error("[BlogSection] Turso client is missing in Astro.locals");
} else {
    try {
        console.log("[BlogSection] Fetching recent posts...");
        const result = await turso.execute({
            sql: "SELECT * FROM posts WHERE STATUS = 'PUBLISHED' ORDER BY createdAt DESC LIMIT 4",
            args: [],
        });

        console.log(`[BlogSection] Found ${result.rows.length} rows.`);

        recentPosts = result.rows.map((post: any) => ({
            title: post.title as string,
            slug: post.slug as string,
            date:
                formatDate(post.createdAt, locale, {
                    month: "short",
                    day: "2-digit",
                    year: "numeric",
                }) ?? "N/A",
        }));
    } catch (error) {
        console.error(
            "[BlogSection] Error fetching recent posts from Turso:",
            error,
        );
    }
}
---

<section
    class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"
    data-aos="fade-up"
    data-aos-duration="800"
    data-aos-once="true"
>
    <header class="mb-10 grid gap-6 lg:grid-cols-[1fr_0.8fr] lg:items-end">
        <div class="grid gap-4 sm:grid-cols-[auto_1fr] sm:items-start">
                <div class="mt-1 hidden h-12 w-12 shrink-0 place-items-center rounded-lg border border-primary-green/30 bg-primary-green/10 text-neutral-100 md:grid [&>svg]:h-7 [&>svg]:w-7">
                    <Coffee />
                </div>
            <div>
                <p class="section-kicker">{t.blogIndex.badge}</p>
                <h2 class="mt-3 max-w-3xl text-balance text-3xl font-semibold leading-tight text-white sm:text-4xl lg:text-5xl">
                    {t.blogSection.heading}
                </h2>
            </div>
        </div>
        <div class="flex flex-col gap-5 lg:items-end">
            <p class="max-w-2xl text-sm leading-7 text-neutral-400 lg:text-right">
                {t.blogSection.description}
            </p>
            <a
                href="/blog"
                class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.22em] text-primary-green transition-colors hover:text-white"
            >
                {t.blogSection.viewAll} <GoToAll />
            </a>
        </div>
    </header>

    <div
        class="surface-panel grid gap-px overflow-hidden bg-white/10"
    >
        {
            recentPosts.map((post) => (
                <a
                    href={`/blog/${post.slug}`}
                    class="group relative flex items-center justify-between bg-black/70 p-5 transition-all duration-300 hover:bg-white/[0.045] md:p-7"
                >
                    <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-8">
                        <span class="min-w-32 font-mono text-xs uppercase tracking-[0.18em] text-neutral-500">
                            {post.date}
                        </span>
                        <h3 class="text-lg font-medium text-neutral-200 transition-colors group-hover:text-primary-green md:text-2xl">
                            {post.title}
                        </h3>
                    </div>
                    <div class="opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-4 group-hover:translate-x-0">
                        <ArrowUpRight className="w-6 h-6 text-primary-green" />
                    </div>

                    <div class="absolute left-0 top-0 h-full w-1 bg-primary-green scale-y-0 group-hover:scale-y-100 transition-transform origin-top duration-300" />
                </a>
            ))
        }
    </div>
</section>
