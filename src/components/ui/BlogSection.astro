---
const { turso } = Astro.locals;
import { ArrowUpRight } from "lucide-react";
import {
    defaultLang,
    localeByLang,
    translations,
    type Language,
} from "@/lib/i18n";
import { formatDate } from "@/lib/date";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
const locale = localeByLang[lang];

let recentPosts: any[] = [];
if (!turso) {
    console.error("[BlogSection] Turso client is missing in Astro.locals");
} else {
    try {
        const result = await turso.execute({
            sql: "SELECT * FROM posts WHERE STATUS = 'PUBLISHED' ORDER BY createdAt DESC LIMIT 4",
            args: [],
        });

        recentPosts = result.rows.map((post: any) => ({
            title: (post.title as string).replace(/[—–]/g, "-"),
            slug: post.slug as string,
            date:
                formatDate(post.createdAt, locale, {
                    month: "short",
                    day: "2-digit",
                    year: "numeric",
                }) ?? "N/A",
        }));
    } catch (error) {
        console.error("[BlogSection] Error fetching recent posts:", error);
    }
}
---

<section
    class="relative mx-auto grid max-w-7xl gap-8 px-5 py-20 sm:px-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start lg:px-12 lg:py-24"
    data-motion-section="blog"
>
    <header class="max-w-3xl lg:sticky lg:top-32" data-motion-header>
        <h2 data-gsap-heading class="max-w-3xl text-balance text-3xl font-semibold leading-tight text-white sm:text-4xl lg:text-[clamp(2rem,3.5vw,2.75rem)]">
            {t.blogSection.heading}
        </h2>
        <p class="mt-5 max-w-2xl text-sm leading-7 text-neutral-400" data-motion-copy>
            {t.blogSection.description}
        </p>
        <a
            href="/blog"
            class="mt-6 inline-flex w-fit items-center gap-2 rounded-lg border border-white/10 bg-white/[0.025] px-4 py-2.5 text-sm font-semibold text-neutral-300 transition-all duration-250 hover:border-primary-green/55 hover:text-primary-green"
        >
            {t.blogSection.viewAll}
            <ArrowUpRight className="h-4 w-4" strokeWidth={1.7} />
        </a>
    </header>

    <div class="grid gap-px overflow-hidden rounded-xl border border-white/8 bg-white/8" data-motion-panel>
        {
            recentPosts.length > 0 ? recentPosts.map((post, i) => (
                <a
                    href={`/blog/${post.slug}`}
                    class="blog-row group relative flex items-center justify-between gap-6 bg-[#0C0C0E] px-5 py-5 transition-all duration-250 hover:bg-white/[0.035] md:px-7"
                    data-blog-row
                >
                    <div class="flex flex-col gap-1.5 md:flex-row md:items-center md:gap-8">
                        <span class="min-w-[7.5rem] font-mono text-[0.6rem] tracking-[0.14em] text-neutral-500">
                            {post.date}
                        </span>
                        <h3 class="text-base font-medium text-neutral-300 transition-colors group-hover:text-white md:text-xl">
                            {post.title}
                        </h3>
                    </div>
                    <div class="shrink-0 opacity-0 translate-x-2 transition-all duration-250 group-hover:opacity-100 group-hover:translate-x-0">
                        <ArrowUpRight className="w-5 h-5 text-primary-green" />
                    </div>
                </a>
            )) : (
                <div class="bg-[#0C0C0E] px-5 py-12 text-center">
                    <p class="font-mono text-[0.7rem] tracking-[0.16em] text-neutral-400">
                        {lang === "es" ? "Artículos próximamente" : "Posts coming soon"}
                    </p>
                </div>
            )
        }
    </div>
</section>
