---
import { defaultLang, translations, type Language } from "@/lib/i18n";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
const [emailExamplePrefix, emailExampleDomain = ""] =
    t.contactForm.emailExample.split("@");
---

<section class="relative z-10">
    <form
        class="precision-tilt flex flex-col gap-5 rounded-xl border border-white/8 bg-[#09090A] p-5 sm:p-6"
        id="contact-form"
        data-motion-panel
        data-tilt-card
        data-sending-text={t.contactForm.sending}
        data-success-text={t.contactForm.success}
        data-error-text={t.contactForm.errorGeneric}
        data-error-prefix={t.contactForm.errorPrefix}
        data-success-prefix={t.contactForm.successPrefix}
    >
        <div class="grid gap-5 md:grid-cols-2">
            <!-- Name -->
            <div class="contact-field flex flex-col gap-2" data-contact-field>
                <label
                    class="font-mono text-[0.65rem] tracking-[0.16em] text-neutral-400"
                    for="name"
                >
                    {t.contactForm.nameLabel}
                    <span class="text-primary-green ml-0.5" aria-hidden="true">*</span>
                </label>
                <input
                    class="contact-input w-full rounded-lg border border-white/8 bg-white/[0.025] px-4 py-3 text-sm text-white outline-none placeholder:text-neutral-400 focus:border-primary-green/60 focus:bg-white/[0.05] focus:ring-2 focus:ring-primary-green/15"
                    type="text"
                    id="name"
                    name="name"
                    required
                    minlength="2"
                    maxlength="120"
                    autocomplete="name"
                    placeholder={t.contactForm.nameExample}
                    aria-describedby="name-error"
                />
                <p id="name-error" class="hidden text-[0.7rem] text-red-400" role="alert" aria-live="polite"></p>
            </div>

            <!-- Email -->
            <div class="contact-field flex flex-col gap-2" data-contact-field>
                <label
                    class="font-mono text-[0.65rem] tracking-[0.16em] text-neutral-400"
                    for="email"
                >
                    {t.contactForm.emailLabel}
                    <span class="text-primary-green ml-0.5" aria-hidden="true">*</span>
                </label>
                <input
                    class="contact-input w-full rounded-lg border border-white/8 bg-white/[0.025] px-4 py-3 text-sm text-white outline-none placeholder:text-neutral-400 focus:border-primary-green/60 focus:bg-white/[0.05] focus:ring-2 focus:ring-primary-green/15"
                    type="email"
                    id="email"
                    name="email"
                    required
                    autocomplete="email"
                    placeholder={`${emailExamplePrefix}@${emailExampleDomain}`}
                    aria-describedby="email-error"
                />
                <p id="email-error" class="hidden text-[0.7rem] text-red-400" role="alert" aria-live="polite"></p>
            </div>
        </div>

        <!-- Message -->
        <div class="contact-field flex flex-col gap-2" data-contact-field>
            <div class="flex items-baseline justify-between">
                <label
                    class="font-mono text-[0.65rem] tracking-[0.16em] text-neutral-400"
                    for="message"
                >
                    {t.contactForm.messageLabel}
                    <span class="text-primary-green ml-0.5" aria-hidden="true">*</span>
                </label>
                <span id="msg-count" class="font-mono text-[0.6rem] text-neutral-500" aria-live="polite">0 / 2000</span>
            </div>
            <textarea
                class="contact-input h-40 w-full resize-none rounded-lg border border-white/8 bg-white/[0.025] px-4 py-3 text-sm text-white outline-none placeholder:text-neutral-400 focus:border-primary-green/60 focus:bg-white/[0.05] focus:ring-2 focus:ring-primary-green/15"
                id="message"
                name="message"
                required
                minlength="10"
                maxlength="2000"
                placeholder={t.contactForm.messageExample}
                aria-describedby="message-error msg-count"
            ></textarea>
            <p id="message-error" class="hidden text-[0.7rem] text-red-400" role="alert" aria-live="polite"></p>
        </div>

        <!-- Submit row -->
        <div class="flex items-center justify-between gap-4">
            <p class="text-xs text-neutral-400">
                {lang === "es" ? "Respondo a todos los mensajes." : "I respond to every message."}
            </p>

            <button
                class="contact-submit group inline-flex items-center gap-2.5 rounded-lg border border-primary-green bg-primary-green px-7 py-3 text-sm font-semibold text-black transition-all duration-200 hover:border-white hover:bg-white active:translate-y-px focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-green/60 focus-visible:ring-offset-2 focus-visible:ring-offset-black disabled:cursor-not-allowed disabled:opacity-50"
                type="submit"
                id="contact-submit"
            >
                <span id="submit-text">{t.contactForm.send}</span>
                <span aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-0.5">→</span>
            </button>
        </div>

        <!-- Feedback message — persistent until dismissed -->
        <div
            id="form-message"
            class="hidden items-start justify-between gap-3 rounded-lg border px-4 py-3 text-sm font-medium"
            role="alert"
            aria-live="assertive"
        >
            <span id="form-message-text"></span>
            <button
                type="button"
                id="form-message-dismiss"
                class="shrink-0 text-current opacity-60 hover:opacity-100 transition-opacity focus-visible:outline-none"
                aria-label={lang === "es" ? "Cerrar mensaje" : "Dismiss message"}
            >
                <span aria-hidden="true">×</span>
            </button>
        </div>
    </form>
</section>

<script>
    import { actions } from 'astro:actions';

    const setupContactForm = () => {
        const form = document.getElementById('contact-form') as HTMLFormElement | null;
        const messageDiv = document.getElementById('form-message');
        const messageText = document.getElementById('form-message-text');
        const dismissBtn = document.getElementById('form-message-dismiss');
        const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
        const submitText = document.getElementById('submit-text');
        const msgCount = document.getElementById('msg-count');
        const textarea = document.getElementById('message') as HTMLTextAreaElement | null;

        if (!form || form.dataset.listenerAttached) return;
        form.dataset.listenerAttached = 'true';

        const originalText = submitText?.textContent ?? 'Send';

        /* Character counter for message */
        textarea?.addEventListener('input', () => {
            const len = textarea.value.length;
            if (msgCount) msgCount.textContent = `${len} / 2000`;
        });

        /* Dismiss handler */
        dismissBtn?.addEventListener('click', () => {
            messageDiv?.classList.add('hidden');
            messageDiv?.classList.remove('flex');
        });

        /* Inline blur validation — field-level, not submit-level */
        const validateField = (field: HTMLInputElement | HTMLTextAreaElement): boolean => {
            const errorEl = document.getElementById(`${field.id}-error`);
            if (!errorEl) return true;

            if (field.validity.valueMissing) {
                const label = field.id === 'name'
                    ? (form.querySelector(`label[for="name"]`)?.textContent?.trim().replace('*', '').trim() ?? 'This field')
                    : field.id === 'email'
                    ? (form.querySelector(`label[for="email"]`)?.textContent?.trim().replace('*', '').trim() ?? 'Email')
                    : (form.querySelector(`label[for="message"]`)?.textContent?.trim().replace('*', '').trim() ?? 'Message');
                errorEl.textContent = `${label} is required.`;
                errorEl.classList.remove('hidden');
                field.classList.add('border-red-500/60');
                field.closest('[data-contact-field]')?.classList.add('is-invalid');
                field.closest('[data-contact-field]')?.classList.remove('is-valid');
                return false;
            }

            if (field.type === 'email' && field.validity.typeMismatch) {
                errorEl.textContent = 'Enter a valid email address.';
                errorEl.classList.remove('hidden');
                field.classList.add('border-red-500/60');
                field.closest('[data-contact-field]')?.classList.add('is-invalid');
                field.closest('[data-contact-field]')?.classList.remove('is-valid');
                return false;
            }

            if (field.validity.tooShort) {
                errorEl.textContent = `Must be at least ${field.minLength} characters.`;
                errorEl.classList.remove('hidden');
                field.classList.add('border-red-500/60');
                field.closest('[data-contact-field]')?.classList.add('is-invalid');
                field.closest('[data-contact-field]')?.classList.remove('is-valid');
                return false;
            }

            /* Clear error */
            errorEl.textContent = '';
            errorEl.classList.add('hidden');
            field.classList.remove('border-red-500/60');
            field.closest('[data-contact-field]')?.classList.remove('is-invalid');
            if (field.value.trim()) {
                field.closest('[data-contact-field]')?.classList.add('is-valid');
            } else {
                field.closest('[data-contact-field]')?.classList.remove('is-valid');
            }
            return true;
        };

        form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach((field) => {
            field.addEventListener('blur', () => validateField(field), { passive: true });
            field.addEventListener('input', () => {
                if (!field.classList.contains('border-red-500/60')) return;
                validateField(field);
            }, { passive: true });
        });

        /* Show feedback message */
        const showMessage = (text: string, isSuccess: boolean) => {
            if (!messageDiv || !messageText) return;
            messageText.textContent = text;
            messageDiv.className = isSuccess
                ? 'feedback-pop flex items-start justify-between gap-3 rounded-lg border border-primary-green/30 bg-primary-green/10 px-4 py-3 text-sm font-medium text-primary-green'
                : 'feedback-pop flex items-start justify-between gap-3 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm font-medium text-red-300';
        };

        /* Submit handler */
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            /* Validate all fields before submitting */
            const fields = Array.from(form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea'));
            const allValid = fields.map(validateField).every(Boolean);
            if (!allValid) {
                fields.find(f => !f.validity.valid)?.focus();
                return;
            }

            const sendingText = form.dataset.sendingText ?? 'Sending...';
            const successText = form.dataset.successText ?? 'Message sent!';
            const errorText = form.dataset.errorText ?? 'An error occurred.';
            const errorPrefix = form.dataset.errorPrefix ?? '✗';
            const successPrefix = form.dataset.successPrefix ?? '✓';

            if (submitBtn) submitBtn.disabled = true;
            if (submitText) submitText.textContent = sendingText;
            messageDiv?.classList.add('hidden');
            messageDiv?.classList.remove('flex');

            try {
                const formData = new FormData(form);
                const { error } = await actions.sendContactEmail(formData);

                if (error) {
                    showMessage(`${errorPrefix} ${error.message || errorText}`, false);
                } else {
                    showMessage(`${successPrefix} ${successText}`, true);
                    form.reset();
                    if (msgCount) msgCount.textContent = '0 / 2000';
                    /* Clear all inline errors */
                    form.querySelectorAll('[id$="-error"]').forEach(el => {
                        el.textContent = '';
                        el.classList.add('hidden');
                    });
                    form.querySelectorAll('[data-contact-field]').forEach((el) => {
                        el.classList.remove('is-valid', 'is-invalid');
                    });
                }
            } catch {
                showMessage(`${errorPrefix} ${errorText}`, false);
            } finally {
                if (submitBtn) submitBtn.disabled = false;
                if (submitText) submitText.textContent = originalText;
            }
        });
    };

    setupContactForm();
    document.addEventListener('astro:page-load', setupContactForm);
    document.addEventListener('astro:after-swap', setupContactForm);
</script>
