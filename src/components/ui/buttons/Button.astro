---
interface Props {
    href?: string;
    text?: string;
    variant?: "primary" | "secondary" | "tertiary";
    className?: string;
    strokeColor?: string;
    width?: string;
    target?: "_blank" | "_self" | "_parent" | "_top";
    ariaLabel?: string;
    rounded?: string;
    justify?: string;
    downloadAttr?: boolean;
    downloadAttributeValue?: string;
}

const {
    target = "_self",
    width = "auto",
    href = "/hire-me",
    text,
    variant = "primary",
    className = "",
    downloadAttr = false,
    ariaLabel = "Button",
    rounded = "lg",
    justify = "center",
    downloadAttributeValue,
} = Astro.props;

const baseStyles = `motion-button px-5 py-2.5 font-semibold rounded-${rounded} transition-all duration-250 group inline-flex justify-${justify} items-center gap-2 w-auto md:w-${width} cursor-pointer whitespace-nowrap text-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-green/60 focus-visible:ring-offset-2 focus-visible:ring-offset-black relative overflow-hidden isolate`;

const variants = {
    primary:
        "text-black min-w-[140px] bg-primary-green border border-primary-green text-center",
    secondary:
        "text-neutral-300 min-w-auto bg-white/[0.025] border border-white/12 text-center",
    tertiary:
        "text-black min-w-[140px] bg-primary-green border border-primary-green text-center",
};
---

<a
    href={href}
    aria-label={ariaLabel}
    target={target}
    data-variant={variant}
    data-micro-button
    data-magnetic
    download={downloadAttr ? downloadAttributeValue : undefined}
    class:list={[baseStyles, variants[variant], className]}
>
    <span data-magnetic-inner class="relative z-[1]">{text}</span>
</a>
