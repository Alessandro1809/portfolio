---
interface Props {
    href?: string;
    text?: string;
    variant?: "primary" | "secondary" | "tertiary";
    className?: string;
    strokeColor?: string;
    width?: string;
    target?: "_blank" | "_self" | "_parent" | "_top";
    ariaLabel?: string;
    rounded?: string;
    justify?: string;
    downloadAttr?: boolean;
    downloadAttributeValue?: string;
}

const {
    target = "_self",
    width = "auto",
    href = "/hire-me",
    text,
    variant = "primary",
    className = "",
    downloadAttr = false,
    ariaLabel = "Button",
    rounded = "full",
    justify = "center",
    downloadAttributeValue,
} = Astro.props;

const baseStyles = `px-5 py-2.5 font-medium rounded-${rounded} transition-all duration-300 group inline-flex justify-${justify} items-center gap-2 w-auto md:w-${width} cursor-pointer whitespace-nowrap text-sm md:text-base font-semibold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-green/70 focus-visible:ring-offset-2 focus-visible:ring-offset-black`;

const variants = {
    primary:
        "text-black min-w-[150px] rounded-full bg-primary-green border border-primary-green text-center shadow-[0_0_28px_rgba(0,212,124,0.18)] hover:bg-white hover:border-white",
    secondary:
        "text-white min-w-auto rounded-full bg-white/[0.03] border border-white/15 backdrop-blur-xl text-center hover:border-primary-green/70 hover:text-primary-green",
    tertiary:
        "text-black min-w-[150px] rounded-md bg-[#84FFD8] border border-[#84FFD8] text-center hover:bg-white hover:border-white",
};
---

<a
    href={href}
    aria-label={ariaLabel}
    target={target}
    download={downloadAttr ? downloadAttributeValue : undefined}
    class:list={[baseStyles, variants[variant], className]}
>
    {text}
</a>
