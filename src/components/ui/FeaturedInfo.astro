---
import { TechStack } from "../react/TechStack";
import { NumberTicker } from "../react/NumberTicker";
import { defaultLang, translations, type Language } from "@/lib/i18n";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];

const stats = [
    { value: 8, label: t.featuredInfo.finishedProjects },
    { value: 3, label: t.featuredInfo.yearsExperience },
    { value: 6, label: t.featuredInfo.happyClients },
];
---

<div class="relative mt-16 overflow-hidden rounded-lg border border-white/10 bg-black/35">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_12%_10%,rgba(0,212,124,0.16),transparent_28rem)]"></div>

    <article
        class="relative z-10 grid gap-8 p-5 sm:p-8 lg:grid-cols-[1fr_0.95fr] lg:p-10"
        data-aos="fade-up"
        data-aos-duration="800"
        data-aos-once="true"
    >
        <TechStack
            client:visible
            title={t.techStack.title}
            closing={t.techStack.closing}
        />

        <div class="flex flex-col justify-center">
            <p class="section-kicker">{t.featuredInfo.heading}</p>
            <div class="mt-8 grid gap-px overflow-hidden rounded-lg border border-white/10 bg-white/10 sm:grid-cols-3">
                {
                    stats.map((stat) => (
                        <div class="bg-black/70 p-5">
                            <span class="flex items-baseline gap-1 text-5xl font-semibold text-white">
                                +
                                <NumberTicker
                                    client:visible
                                    value={stat.value}
                                    className="drop-shadow-[0_0_18px_rgba(0,212,124,0.35)]"
                                />
                            </span>
                            <p class="mt-3 text-sm leading-5 text-neutral-400">
                                {stat.label}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </article>
</div>
