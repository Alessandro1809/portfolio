---
import Contact from "@/components/ui/forms/Contact.astro";
import { defaultLang, translations, type Language } from "@/lib/i18n";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
---

<section
    class="relative mx-auto grid max-w-7xl gap-7 px-5 py-14 sm:px-8 lg:grid-cols-[0.72fr_1.28fr] lg:items-start lg:px-12 lg:py-16"
    data-motion-section="contact"
>
    <header
        class="max-w-2xl"
        data-motion-header
    >
        <h2 data-gsap-heading class="text-3xl font-semibold leading-tight text-white sm:text-4xl lg:text-[clamp(2rem,3.4vw,2.85rem)]">
            {t.contactSection.heading}
        </h2>
        <p class="mt-5 max-w-2xl text-base leading-[1.8] text-neutral-400" data-motion-copy>
            {t.contactSection.description}
        </p>
    </header>

    <div data-motion-panel>
        <Contact />
    </div>
</section>
