---
import Contact from "@/components/ui/forms/Contact.astro";
import { defaultLang, translations, type Language } from "@/lib/i18n";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
---

<section
    class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8"
>
    <header
        class="grid gap-5 lg:grid-cols-[0.9fr_1fr] lg:items-end"
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="100"
        data-aos-once="true"
    >
        <div>
            <p class="section-kicker">{t.footer.getInTouch}</p>
            <h2 class="mt-4 text-3xl font-semibold text-white sm:text-5xl">
                {t.contactSection.heading}
            </h2>
        </div>
        <p class="max-w-3xl text-base leading-8 text-neutral-300 lg:justify-self-end lg:text-right">
            {t.contactSection.description}
        </p>
    </header>
    <article
        data-aos="fade-up"
        data-aos-duration="1000"
        data-aos-delay="100"
        data-aos-once="true"
    >
        <Contact />
    </article>
</section>
