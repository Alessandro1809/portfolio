---
import avatar2 from "@/assets/avatar2.png";
import { defaultLang, translations, type Language } from "@/lib/i18n";

const lang = (Astro.locals.lang as Language | undefined) ?? defaultLang;
const t = translations[lang];
---

<section class="flex min-h-[27rem] items-start justify-center overflow-hidden rounded-md bg-black/50 p-5">
    <div class="relative w-full max-w-sm">
        <div class="absolute -inset-8 rounded-full bg-primary-green/20 blur-3xl"></div>
        <div class="relative overflow-hidden rounded-lg border border-primary-green/30 bg-[radial-gradient(circle_at_50%_20%,rgba(232,168,48,0.16),transparent_38%),linear-gradient(180deg,rgba(255,255,255,0.06),rgba(255,255,255,0.02))]">
            <div class="absolute inset-0 bg-[linear-gradient(110deg,transparent_0%,rgba(255,255,255,0.08)_42%,transparent_58%)]"></div>
            <img
                class="relative z-10 mx-auto h-[24rem] w-auto object-contain drop-shadow-[0_30px_70px_rgba(0,0,0,0.65)]"
                src={avatar2.src}
                alt="Alessandro Diaz"
                loading="lazy"
                decoding="async"
            />
            <div class="absolute bottom-0 left-0 right-0 z-20 border-t border-white/10 bg-black/65 p-4 backdrop-blur-xl">
                <h3 class="text-xl font-semibold text-white">Alessandro Diaz</h3>
                <p class="mt-1 font-mono text-xs uppercase tracking-[0.2em] text-primary-green">
                    {t.profile.title}
                </p>
            </div>
        </div>
    </div>
</section>
