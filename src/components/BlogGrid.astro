---
import { BlogCard } from "./cards/BlogCard";
import { turso } from "@/lib/turso";

const result = await turso.execute({
    sql: "SELECT * FROM posts WHERE STATUS = 'PUBLISHED' ORDER BY createdAt DESC",
    args: [],
});

const blogPosts = result.rows.map((post: any) => ({
    id: post.id,
    title: post.title,
    slug: post.slug,
    featuredImage: post.featuredImage,
    excerpt: post.excerpt,
    date: new Date(post.createdAt).toLocaleDateString().split("T")[0],
    categorie: post.categorie,
    tags: post.tags,
    read_time: post.read_time,
    featured: Boolean(post.featured),
}));
---

<section class="container mx-auto px-4 py-16 md:py-24">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {blogPosts.map((post: any) => <BlogCard client:load post={post} />)}
    </div>
</section>
